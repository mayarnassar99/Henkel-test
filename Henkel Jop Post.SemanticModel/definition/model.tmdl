model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["Dim_Channel","Dim_Customer","Dim_Product","Dim_Region","Dim_Time","Fact_MarketShare","Fact_Pricing","Fact_Profitability","Fact_Promotion","Fact_Sales"]

annotation PBI_ProTooling = ["DevMode"]

ref table Dim_Channel
ref table Dim_Customer
ref table Dim_Product
ref table Dim_Region
ref table Dim_Time
ref table Fact_MarketShare
ref table Fact_Pricing
ref table Fact_Profitability
ref table Fact_Promotion
ref table Fact_Sales

ref cultureInfo en-US

